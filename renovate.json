{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "configMigration": true,
  "ignoreTests": true,
  "flux": {
    "managerFilePatterns": [
      "/^(apps|clusters|infrastructure)\\/.*\\.ya?ml$/"
    ]
  },
  "packageRules": [
    {
      "versioning": "semver",
      "matchManagers": ["flux"],
      "matchDatasources": [
        "docker"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true,
      "matchPackageNames": [
        "ghcr.io/renovatebot/charts/renovate"
      ]
    },
    {
      "abandonmentThreshold": "1 year",
      "matchPackageNames": [
        "*"
      ]
    }
  ]
}